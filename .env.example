# Local runtime
# Use APP_BASE_URL to build absolute Stripe success/cancel/webhook URLs.
# APP_DATA_PATH defaults to ./data/app-store.json locally.
# Set it explicitly in deployment to a writable persistent path.

PORT=5000
APP_BASE_URL=https://fintechlawyer.ca
APP_DATA_PATH=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
